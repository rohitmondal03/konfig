{
  "name": "konfig",
  "private": true,
  "workspace": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "api:dev": "turbo run dev --filter=api",
    "sdk:build": "turbo run build --filter=@konfig/sdk",
    "web:dev": "turbo run dev --filter=web"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}